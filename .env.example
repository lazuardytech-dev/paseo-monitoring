# === Required ===
# Password for login authentication (change immediately)
PASEO_MONITORING_PASSWORD=changeme

# HMAC secret for session tokens (min 32 characters, recommend 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASEO_MONITORING_SESSION_SECRET=replace-with-64-char-hex-secret-minimum-32-chars-long

# === Optional ===
# Bind address (default: 127.0.0.1)
# WARNING: Do NOT expose to 0.0.0.0 without HTTPS + auth in production
HOST=127.0.0.1

# HTTP port (default: 6004)
PORT=6004

# Set to "production" for secure cookies (requires HTTPS)
# In production, also set COOKIE_SECURE=true or terminate TLS at reverse proxy
NODE_ENV=production

# Force secure cookies even without NODE_ENV=production
# COOKIE_SECURE=true

# Path to daemon state cache file (default: /tmp/paseo-monitoring-state.json)
# Use a directory only readable by the app user for production
# STATE_FILE_PATH=/var/lib/paseo-monitoring/state.json
