{
  "name": "paseo-monitoring",
  "version": "0.1.0",
  "description": "Paseo daemon monitoring dashboard",
  "main": "server/index.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 6004",
    "build": "vite build",
    "start": "bun server/index.js",
    "start:collector": "node server/collector.js",
    "start:all": "pm2 start server/collector.js --name paseo-monitoring-collector && pm2 start server/index.js --name paseo-monitoring",
    "preview": "vite preview --host 127.0.0.1 --port 6004",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "bun run lint && bun run build && bun run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lucide-react": "^1.17.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "private": true
}
